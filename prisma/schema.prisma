// prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ADMINS
// ─────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

model Admin {
  id                 String    @id @default(uuid())
  name               String
  email              String    @unique
  password           String
  role               AdminRole
  isBlocked          Boolean   @default(false)
  mustChangePassword Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  couponsCreated  Coupon[]
  statusHistories OrderStatusHistory[]
  bannersCreated  Banner[]
  inventoryLogs   InventoryLog[]

  @@map("admins")
}

// ─────────────────────────────────────────
// BRANDS
// ─────────────────────────────────────────

model Brand {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logo        String?
  description String?
  country     String?
  isActive    Boolean  @default(true)
  deleted     Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@map("brands")
}

// ─────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────

enum CategoryType {
  PRODUCT
  SKIN_TYPE
  CONCERN
}

model Category {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String?
  image       String?
  sizeChart   String?
  order       Int          @default(0)
  parentId    String?
  type        CategoryType @default(PRODUCT)
  isActive    Boolean      @default(true)
  deleted     Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  parent   Category?  @relation("CategorySelf", fields: [parentId], references: [id])
  children Category[] @relation("CategorySelf")
  products Product[]

  couponCategories         CouponCategory[]
  deliveryChargeCategories DeliveryChargeCategory[]

  @@map("categories")
}

// ─────────────────────────────────────────
// TAGS (skin concern / type filtering)
// ─────────────────────────────────────────
enum TagType {
  SKIN_TYPE
  CONCERN
  INGREDIENT
  FEATURE
  ROUTINE
  TEXTURE
  AGE_GROUP
  SPF_TYPE
  GENDER
}

model Tag {
  id   String  @id @default(uuid())
  name String  @unique
  slug String  @unique
  type TagType @default(SKIN_TYPE)

  products ProductTag[]

  @@map("tags")
}

model ProductTag {
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([productId, tagId])
  @@map("product_tags")
}

// ─────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────

model Product {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  description    String?
  howToUse       String?
  ingredients    String?
  categoryId     String
  brandId        String?
  basePrice      Decimal  @db.Decimal(10, 2)
  compareAtPrice Decimal? @db.Decimal(10, 2)
  appPrice       Decimal? @db.Decimal(10, 2)
  images         String[]
  sku            String?  @unique
  deleted        Boolean  @default(false)
  newArrival     Boolean  @default(false)
  isFeatured     Boolean  @default(false)
  isOnOffer      Boolean  @default(false)
  productOrder   Int      @default(0)
  isActive       Boolean  @default(true)
  averageRating  Float    @default(0)
  reviewCount    Int      @default(0)
  soldCount      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category               Category                @relation(fields: [categoryId], references: [id])
  brand                  Brand?                  @relation(fields: [brandId], references: [id])
  variants               ProductVariant[]
  orderItems             OrderItem[]
  reviews                Review[]
  tags                   ProductTag[]
  couponProducts         CouponProduct[]
  inventoryLogs          InventoryLog[]
  deliveryChargeProducts DeliveryChargeProduct[]

  @@index([deleted, isActive, productOrder])
  @@index([categoryId])
  @@index([brandId])
  @@index([slug])
  @@map("products")
}

// ─────────────────────────────────────────
// PRODUCT VARIANTS (size / weight / shade)
// ─────────────────────────────────────────

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String
  label         String
  stock         Int      @default(0)
  priceOverride Decimal? @db.Decimal(10, 2)
  sku           String?

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  inventoryLogs InventoryLog[]

  @@map("product_variants")
}

// ─────────────────────────────────────────
// INVENTORY LOGS
// ─────────────────────────────────────────

enum InventoryChangeType {
  RESTOCK
  SALE
  RETURN
  ADJUSTMENT
}

model InventoryLog {
  id          String              @id @default(uuid())
  productId   String
  variantId   String?
  changeType  InventoryChangeType
  qty         Int
  note        String?
  changedById String?
  createdAt   DateTime            @default(now())

  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  changedBy Admin?          @relation(fields: [changedById], references: [id])

  @@map("inventory_logs")
}

// ─────────────────────────────────────────
// BANNERS
// ─────────────────────────────────────────

enum BannerPosition {
  HERO
  PROMO
  POPUP
}

model Banner {
  id          String         @id @default(uuid())
  title       String?
  subtitle    String?
  description String?
  image       String?
  mobileImage String?
  linkUrl     String?
  buttonText  String?
  buttonLink  String?
  slides      Json? // HERO: [{image,mobileImage?,title?,subtitle?,buttonText?,buttonLink?}]
  position    BannerPosition @default(HERO)
  isActive    Boolean        @default(true)
  deleted     Boolean        @default(false)
  order       Int            @default(0)
  validFrom   DateTime?
  validUntil  DateTime?
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdBy Admin @relation(fields: [createdById], references: [id])

  @@map("banners")
}

// ─────────────────────────────────────────
// HOMEPAGE SECTIONS
// ─────────────────────────────────────────

enum HomepageSectionType {
  BANNER
  PRODUCT_GRID
  CATEGORY_GRID
  BRAND_GRID
  YOUTUBE_VIDEOS
  ANNOUNCEMENT_BAR
  CUSTOM_HTML
}

model HomepageSection {
  id        String              @id @default(uuid())
  title     String?
  subtitle  String?
  type      HomepageSectionType
  order     Int                 @default(0)
  isActive  Boolean             @default(true)
  deleted   Boolean             @default(false)
  config    String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  items HomepageSectionItem[]

  @@map("homepage_sections")
}

enum SectionItemType {
  PRODUCT
  CATEGORY
  BRAND
  BANNER
  VIDEO
}

model HomepageSectionItem {
  id        String          @id @default(uuid())
  sectionId String
  refType   SectionItemType
  refId     String?
  title     String?
  image     String?
  linkUrl   String?
  order     Int             @default(0)
  createdAt DateTime        @default(now())

  section HomepageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("homepage_section_items")
}

// ─────────────────────────────────────────
// YOUTUBE VIDEOS
// ─────────────────────────────────────────

model YoutubeVideo {
  id          String   @id @default(uuid())
  title       String
  youtubeId   String   @unique
  thumbnail   String?
  description String?
  isActive    Boolean  @default(true)
  deleted     Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("youtube_videos")
}

// ─────────────────────────────────────────
// ANNOUNCEMENTS
// ─────────────────────────────────────────

model Announcement {
  id        String   @id @default(uuid())
  text      String
  linkUrl   String?
  isActive  Boolean  @default(true)
  deleted   Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model DeliveryChargeConfig {
  id           String   @id @default(uuid())
  key          String   @unique @default("default")
  insideDhaka  Decimal  @default(60) @db.Decimal(10, 2)
  outsideDhaka Decimal  @default(120) @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("delivery_charge_configs")
}

enum DeliveryChargeZone {
  inside
  outside
}

enum DeliveryChargeScope {
  all
  category
  subcategory
  product
}

model DeliveryChargeRule {
  id        String              @id @default(uuid())
  zone      DeliveryChargeZone
  scope     DeliveryChargeScope
  charge    Decimal             @db.Decimal(10, 2)
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  categories DeliveryChargeCategory[]
  products   DeliveryChargeProduct[]

  @@index([zone, scope, isActive])
  @@map("delivery_charge_rules")
}

model DeliveryChargeCategory {
  ruleId     String
  categoryId String

  rule     DeliveryChargeRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  category Category           @relation(fields: [categoryId], references: [id])

  @@id([ruleId, categoryId])
  @@map("delivery_charge_categories")
}

model DeliveryChargeProduct {
  ruleId    String
  productId String

  rule    DeliveryChargeRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  product Product            @relation(fields: [productId], references: [id])

  @@id([ruleId, productId])
  @@map("delivery_charge_products")
}

// ─────────────────────────────────────────
// COUPONS
// ─────────────────────────────────────────

enum CouponType {
  percentage
  fixed
}

model Coupon {
  id                   String     @id @default(uuid())
  code                 String     @unique
  description          String?
  type                 CouponType
  value                Decimal    @db.Decimal(10, 2)
  minOrderAmount       Decimal?   @db.Decimal(10, 2)
  maxDiscountAmount    Decimal?   @db.Decimal(10, 2)
  usageLimit           Int
  usedCount            Int        @default(0)
  validFrom            DateTime
  validUntil           DateTime
  isActive             Boolean    @default(true)
  createdById          String
  appliesToAllProducts Boolean    @default(true)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  createdBy  Admin            @relation(fields: [createdById], references: [id])
  orders     Order[]
  categories CouponCategory[]
  products   CouponProduct[]

  @@map("coupons")
}

model CouponCategory {
  couponId   String
  categoryId String

  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@id([couponId, categoryId])
  @@map("coupon_categories")
}

model CouponProduct {
  couponId  String
  productId String

  coupon  Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@id([couponId, productId])
  @@map("coupon_products")
}

// ─────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────

enum PaymentMethod {
  COD
  BKASH
  NAGAD
  CARD
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

model Order {
  id                     String        @id @default(uuid())
  trackingNumber         String        @unique
  customerName           String
  email                  String?
  mobile                 String
  district               String
  upazila                String
  addressLine            String
  postalCode             String?
  deliveryChargeZone     String?
  orderNote              String?
  isGuestOrder           Boolean       @default(true)
  subtotal               Decimal       @db.Decimal(10, 2)
  shipping               Decimal       @default(0) @db.Decimal(10, 2)
  couponId               String?
  discountAmount         Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount            Decimal       @db.Decimal(10, 2)
  paymentMethod          PaymentMethod @default(COD)
  paymentStatus          PaymentStatus @default(pending)
  transactionId          String?
  paymentGatewayResponse String?
  steadfastConsignmentId Int?
  steadfastTrackingCode  String?
  steadfastStatus        String?
  steadfastRequestedAt   DateTime?
  steadfastResponse      Json?
  status                 OrderStatus   @default(pending)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  coupon          Coupon?              @relation(fields: [couponId], references: [id])
  items           OrderItem[]
  statusHistories OrderStatusHistory[]
  reviews         Review[]

  @@map("orders")
}

model OrderItem {
  id               String  @id @default(uuid())
  orderId          String
  productId        String
  productVariantId String?
  title            String
  variantLabel     String?
  image            String
  quantity         Int
  unitPrice        Decimal @db.Decimal(10, 2)
  totalPrice       Decimal @db.Decimal(10, 2)

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id])
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id          String      @id @default(uuid())
  orderId     String
  status      OrderStatus
  note        String?
  changedById String?
  changedAt   DateTime    @default(now())

  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy Admin? @relation(fields: [changedById], references: [id])

  @@map("order_status_histories")
}

// ─────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────

model Review {
  id             String   @id @default(uuid())
  productId      String
  orderId        String
  customerName   String
  rating         Int
  comment        String
  isApproved     Boolean  @default(false)
  showOnHomepage Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  @@unique([productId, orderId])
  @@map("reviews")
}

// ─────────────────────────────────────────
// VISITORS
// ─────────────────────────────────────────

model Visitor {
  id        String   @id @default(uuid())
  ip        String?
  userAgent String?
  page      String?
  referrer  String?
  country   String?
  device    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("visitors")
}
