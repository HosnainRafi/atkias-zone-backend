NODE_ENV=development
PORT=5000

# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=atkias_zone
DB_PORT=5432

# MongoDB Configuration (for migration from MongoDB)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=AppName
MONGODB_DB_NAME=test

# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRES_IN=7d

# Bcrypt Configuration
BCRYPT_SALT_ROUNDS=10

# SMTP Configuration
SMTP_HOST=mail.outfitro.com
SMTP_PORT=465
SMTP_USER=order@outfitro.com
SMTP_PASS=your-smtp-password
ADMIN_EMAIL=admin@atkiaszone.com

# Prisma Database URL (constructed from above variables)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atkias_zone

# bKash Payment Gateway
# Sandbox credentials — replace with production credentials before going live
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
BKASH_USERNAME=your-bkash-username
BKASH_PASSWORD=your-bkash-password
# Sandbox URL (default if unset). Production: https://tokenized.pay.bka.sh/v1.2.0-beta/tokenized
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta/tokenized

# URLs used for bKash callback redirect
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
